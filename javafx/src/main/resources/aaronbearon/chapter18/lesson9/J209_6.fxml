<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane onMouseMoved="#makeShapes" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="aaronbearon.chapter18.lesson9.J209_6controller">
   <top>
      <HBox alignment="CENTER" prefHeight="50.0" prefWidth="600.0" spacing="10.0" BorderPane.alignment="CENTER">
         <children>
            <TextField fx:id="txtIn" />
            <Button fx:id="makeSquares" mnemonicParsing="false" text="Set Squares" />
         </children>
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding></HBox>
   </top>
   <bottom>
      <HBox alignment="CENTER" prefHeight="50.0" prefWidth="600.0" BorderPane.alignment="CENTER">
         <children>
            <Slider fx:id="slider" max="50.0" min="-50.0" prefHeight="38.0" prefWidth="300.0" showTickLabels="true" showTickMarks="true" />
         </children></HBox>
   </bottom>
   <center>
      <Pane fx:id="pane" prefHeight="300.0" prefWidth="600.0" BorderPane.alignment="CENTER" />
   </center>
</BorderPane>
