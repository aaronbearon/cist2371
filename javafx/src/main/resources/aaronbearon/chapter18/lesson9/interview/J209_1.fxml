<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<VBox alignment="CENTER" prefHeight="300.0" prefWidth="400.0" spacing="10.0" xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1" fx:controller="aaronbearon.chapter18.lesson9.interview.J209_1_controller">
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
    </padding>
    <Label text="Enter number to display sum of numbers up to that number"/>
    <TextField fx:id="txtIn"/>
    <Button mnemonicParsing="false" onAction="#onCalculate" text="Calculate"/>
    <TextField fx:id="txtOut" editable="false"/>
</VBox>
