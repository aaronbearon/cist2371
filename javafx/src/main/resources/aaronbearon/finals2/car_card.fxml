<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="10.0" prefWidth="200.0"
      style="-fx-border-color: #cccccc; -fx-border-radius: 5; -fx-background-color: #f9f9f9;"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>
    <children>
        <Label fx:id="carName" style="-fx-font-weight: bold; -fx-font-size: 14;" text="Brand Name" />

        <ImageView fx:id="carImage" fitWidth="180.0" preserveRatio="true" />

        <Label fx:id="carPrice" style="-fx-text-fill: #2e7d32; -fx-font-weight: bold;" text="\$0.00" />
    </children>
</VBox>