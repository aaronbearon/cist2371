<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<VBox alignment="CENTER" spacing="10.0" prefWidth="200.0"
      style="-fx-border-color: #cccccc; -fx-border-radius: 5; -fx-background-color: #f9f9f9;"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
    </padding>
    <children>
        <Label fx:id="carName" style="-fx-font-weight: bold; -fx-font-size: 14;" text="Lamborghini"/>

        <StackPane minWidth="180.0" prefWidth="180.0" maxWidth="180.0"
                   minHeight="100.0" prefHeight="100.0" maxHeight="100.0">
            <ImageView fx:id="carImage" fitWidth="180.0" fitHeight="100" preserveRatio="true"/>
        </StackPane>

        <Label fx:id="carPrice" style="-fx-text-fill: #2e7d32; -fx-font-weight: bold;" text="\$150,000.00"/>
    </children>
</VBox>